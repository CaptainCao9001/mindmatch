classDiagram
    direction LR

    class UnifiedProfile {
        +string userId
        +number generatedAt
        +Record~DimensionId, number|null~ dimensions
        +Record~DimensionId, number|null~ raw
        +object meta
    }

    class ProfileEntry {
        +DimensionId field
        +number ideal
        +string direction
        +number weight
    }

    class DirectionProfile {
        +string id
        +string name
        +string slogan
        +string description
        +string icon
        +object gameWeights
        +ProfileEntry[] profiles
    }

    class JobVariant {
        +string id
        +string name
        +string directionId
        +string icon
        +string description
        +object delta
    }

    class DirectionDataSet {
        +object directions
        +object directionJobs
        +object jobs
    }

    class DirectionMatchEntry {
        +string directionId
        +string directionName
        +string directionIcon
        +string directionSlogan
        +string directionDescription
        +number score
        +number topsisCloseness
        +number topsisRank
        +number linearScore
        +object breakdown
        +JobMatchEntry[] jobResults
    }

    class JobMatchEntry {
        +string jobId
        +string jobName
        +string jobIcon
        +string jobDescription
        +number score
        +number topsisCloseness
        +number internalRank
        +number linearScore
        +object breakdown
        +ProfileEntry[] _resolvedProfiles
    }

    class ExtendedMatchReport {
        +UnifiedProfile profile
        +DirectionMatchEntry[] directionRanking
        +object tracks
        +boolean needsAIReview
        +number generatedAt
    }

    class MatchReport {
        +UnifiedProfile profile
        +Array~Object~ ranking
        +object tracks
        +boolean needsAIReview
        +number generatedAt
    }

    class matcher_linear {
        +linearMatch(profile, jobs)
        +mapSubDimension(actual, direction)
        +gameLevelBreakdown(userProfile, jobProfile)
    }

    class matcher_topsis {
        +topsisMatch(profile, jobs)
        +needsAIReview(linearResults, topsisResults)
    }

    class matcher_extended {
        +directionMatch(profile, directions)
        +jobMatch(profile, directionProfile, jobVariants)
        +resolveJobProfile(directionProfile, jobVariant)
    }

    class matcher {
        +match(profile, jobs)
        +matchExtended(profile, data)
    }

    class match_ui {
        +renderMatchResults(containerId, report)
        +getRankColor(rank)
        +getGameColor(game)
        +getGameLabel(game)
        +createEl(tag, className)
    }

    class match_ui_extended {
        +renderDirectionResults(containerId, report)
        +renderDirectionCard(entry, rank, isExpanded)
        +renderJobList(jobResults)
    }

    DirectionProfile "1" --> "1..14" ProfileEntry : profiles
    DirectionDataSet "1" --> "6" DirectionProfile : directions
    DirectionDataSet "1" --> "54" JobVariant : directionJobs
    JobVariant "1" --> "1" DirectionProfile : inherits from
    DirectionMatchEntry "1" --> "0..9" JobMatchEntry : jobResults
    ExtendedMatchReport "1" --> "1" UnifiedProfile : profile
    ExtendedMatchReport "1" --> "6" DirectionMatchEntry : directionRanking
    matcher ..> matcher_linear : imports
    matcher ..> matcher_topsis : imports
    matcher ..> matcher_extended : imports
    matcher_extended ..> matcher_linear : imports
    matcher_extended ..> matcher_topsis : imports
    match_ui_extended ..> match_ui : imports helpers
