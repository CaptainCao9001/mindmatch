sequenceDiagram
    actor User as 用户
    participant MatchHTML as match.html
    participant Integrator as integrator.js
    participant Store as store.js
    participant Matcher as matcher.js
    participant MatcherExt as matcher_extended.js
    participant Linear as matcher_linear.js
    participant Topsis as matcher_topsis.js
    participant UI as match-ui-extended.js
    participant DOM as 浏览器 DOM

    User->>MatchHTML: 访问 match.html?mode=extended
    MatchHTML->>Integrator: integrate()
    Integrator->>Store: loadAll()
    Store-->>Integrator: G1-G4 游戏数据
    Integrator-->>MatchHTML: UnifiedProfile (14维 [0,1])

    MatchHTML->>MatchHTML: fetch('./mock/ideal-profiles.json')
    MatchHTML-->>MatchHTML: DirectionDataSet {directions, directionJobs}

    MatchHTML->>Matcher: matchExtended(profile, data)

    rect rgb(40, 40, 70)
        Note over Matcher,MatcherExt: === 第一级：6 方向匹配 ===

        Matcher->>MatcherExt: directionMatch(profile, data.directions)
        MatcherExt->>Linear: linearMatch(profile, directions)
        Linear-->>MatcherExt: [{directionId, score, dimDetails} ×6]
        MatcherExt->>Topsis: topsisMatch(profile, directions)
        Topsis-->>MatcherExt: [{directionId, closeness, dPlus, dMinus} ×6]
        MatcherExt-->>Matcher: DirectionMatchEntry[] (6条，按score降序)
    end

    rect rgb(40, 70, 40)
        Note over Matcher,MatcherExt: === 第二级：top1 方向内的职业匹配 ===

        Matcher->>MatcherExt: jobMatch(profile, topDirection, jobVariants)
        loop 对每个 jobVariant (共9个)
            MatcherExt->>MatcherExt: resolveJobProfile(directionBaseline, jobDelta)
            MatcherExt->>Linear: linearScoreForJob(userDims, resolvedProfile)
            Linear-->>MatcherExt: {jobId, score, dimDetails}
        end
        MatcherExt-->>Matcher: JobMatchEntry[] (9条，按score降序)
    end

    Matcher-->>MatchHTML: ExtendedMatchReport

    MatchHTML->>UI: renderDirectionResults('matchContent', report)
    UI->>DOM: 渲染 6 张方向卡片
    UI->>DOM: top1 方向展开显示 9 职业列表
    UI->>DOM: 其余方向折叠显示 "查看详情 ▼"

    User->>DOM: 点击折叠方向 "查看详情 ▼"
    DOM->>UI: toggle事件 → Lazy jobMatch
    UI->>MatcherExt: jobMatch(profile, clickedDirection, jobVariants)
    MatcherExt-->>UI: JobMatchEntry[]
    UI->>DOM: 展开显示该方向的 9 职业列表
