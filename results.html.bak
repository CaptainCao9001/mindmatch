<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MindMatch — 思维肖像</title>
  <meta name="description" content="基于你在 4 个思维游戏中的表现，生成的专属思维肖像。">
  <!-- 模块版本号：更新 JS 后改这个值强制浏览器刷新缓存 -->
  <script>window.__MM_VER__ = '20260610b';</script>
  <link rel="stylesheet" href="css/base.css?v=20260610b">
  <link rel="stylesheet" href="css/components.css?v=20260610b">
  <link rel="stylesheet" href="css/results.css?v=20260610b">
</head>
<body class="page-results">

  <!-- ========== Hero ========== -->
  <section class="results-hero">
    <h1>你的思维肖像</h1>
    <div class="completion-badge" id="completionBadge">加载中...</div>
    <div id="confidenceBanner"></div>
  </section>

  <!-- ========== 维度概览（4 张图表卡片） ========== -->
  <div class="overview-grid" id="overviewGrid">
    <!-- 由 portrait.js 渲染 -->
  </div>

  <!-- ========== 分割线 ========== -->
  <div class="section-divider"><span>肖像报告</span></div>

  <!-- ========== 肖像报告 ========== -->
  <section class="portrait-section">
    <div id="portraitContainer">
      <!-- 由 portrait.js 渲染 -->
    </div>
  </section>

  <!-- ========== 分割线 ========== -->
  <div class="section-divider"><span>AI 深度解读</span></div>

  <!-- ========== AI 解读区域 ========== -->
  <section class="insight-section">
    <div id="insightTriggerContainer"></div>
    <div id="insightCardContainer"></div>
  </section>

  <!-- ========== 分割线 ========== -->
  <div class="section-divider"><span>职业匹配</span></div>

  <!-- ========== 岗位匹配 ========== -->
  <section class="match-section" id="matchSection">
    <div id="matchContainer">
      <div class="match-placeholder match-trigger" id="matchFallback">
        <div class="match-trigger-icon">🎯</div>
        <h3>职业匹配分析</h3>
        <p>所有游戏已完成！基于你的思维肖像，看看哪些岗位与你最匹配</p>
        <button class="btn-match-trigger" onclick="location.href='match.html?mode=extended'">查看职业方向</button>
      </div>
    </div>
  </section>

  <!-- ========== Career Guide CTA ========== -->
  <div style="
    max-width:800px;margin:var(--space-8) auto 0;padding:0 var(--space-4);text-align:center;
  ">
    <a href="career-guide.html?from=assessment" style="
      display:inline-flex;align-items:center;gap:10px;
      padding:16px 32px;
      background:linear-gradient(135deg,rgba(16,185,129,0.12),rgba(124,58,237,0.08));
      border:1px solid rgba(16,185,129,0.3);
      border-radius:14px;
      color:var(--color-text);
      font-size:16px;
      font-weight:600;
      text-decoration:none;
      transition:all .25s;
    " onmouseover="this.style.borderColor='rgba(16,185,129,0.5)';this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 24px rgba(16,185,129,0.12)'"
       onmouseout="this.style.borderColor='rgba(16,185,129,0.3)';this.style.transform='translateY(0)';this.style.boxShadow='none'">
      🔍 探索你的职业方向
      <svg viewBox="0 0 24 24" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
    </a>
    <p style="color:var(--color-text-muted);font-size:13px;margin-top:10px;">基于你的测评画像，AI 带你一步步理清职业方向</p>
  </div>

  <!-- ========== Footer ========== -->
  <div class="results-footer">
    <a href="index.html">返回首页</a>
    <button id="btnRestart">重新开始</button>
    <button id="btnExportReport" class="btn-export">📄 导出报告</button>
  </div>

  <!-- ========== ECharts CDN ========== -->
  <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

  <!-- ========== 错误诊断（非模块，最早执行） ========== -->
  <script>
    window.__DIAG__ = [];
    window.addEventListener('error', function(e) {
      var msg = '[JS Error] ' + (e.message || 'unknown') + ' @ ' + (e.filename || '?') + ':' + (e.lineno || '?');
      window.__DIAG__.push(msg);
      var badge = document.getElementById('completionBadge');
      if (badge) { badge.textContent = '脚本错误'; badge.style.color = '#f87171'; }
    }, true);
    window.addEventListener('unhandledrejection', function(e) {
      var msg = '[Promise Error] ' + (e.reason ? (e.reason.message || e.reason) : 'unknown');
      window.__DIAG__.push(msg);
    });
  </script>

  <!-- ========== App Script ========== -->
  <script type="module">
    import { clear, load } from './js/core/store.js';

    const VER = `?v=${window.__MM_VER__ || '1'}`;

    let _profile = null;
    let _translation = null;

    // 所有 JS 模块通过动态 import + 版本号加载，彻底破除 CDN 缓存
    let _integrate = null;
    let _translate = null;
    let _renderOverviewCards = null;
    let _renderPortrait = null;
    let _renderAllCharts = null;
    let _generateInsight = null;
    let _hasInsightCache = null;
    let _renderInsightTrigger = null;
    let _renderInsightLoading = null;
    let _renderInsightSuccess = null;
    let _renderInsightError = null;
    let _extractBehaviorNarrative = null;
    let _formatBehaviorNarrative = null;
    let _behaviorNarrativeText = '';

    async function loadCoreModules() {
      const [integratorMod, translatorMod, portraitMod, chartsMod] = await Promise.all([
        import(`./js/layers/integrator.js${VER}`),
        import(`./js/layers/translator.js${VER}`),
        import(`./js/ui/portrait.js${VER}`),
        import(`./js/ui/charts.js${VER}`),
      ]);
      _integrate = integratorMod.integrate;
      _translate = translatorMod.translate;
      _renderOverviewCards = portraitMod.renderOverviewCards;
      _renderPortrait = portraitMod.renderPortrait;
      _renderAllCharts = chartsMod.renderAllCharts;
      console.log('[MindMatch] 核心模块加载成功 ✅');
    }

    async function loadAIModules() {
      try {
        const [insightMod, cardMod, bnMod] = await Promise.all([
          import(`./js/layers/insight.js${VER}`),
          import(`./js/ui/insight-card.js${VER}`),
          import(`./js/layers/behavior-narrative.js${VER}`),
        ]);
        _generateInsight = insightMod.generateInsight;
        _hasInsightCache = insightMod.hasInsightCache;
        _renderInsightTrigger = cardMod.renderInsightTrigger;
        _renderInsightLoading = cardMod.renderInsightLoading;
        _renderInsightSuccess = cardMod.renderInsightSuccess;
        _renderInsightError = cardMod.renderInsightError;
        _extractBehaviorNarrative = bnMod.extractBehaviorNarrative;
        _formatBehaviorNarrative = bnMod.formatBehaviorNarrative;
        console.log('[MindMatch] AI 模块加载成功 ✅');
        return true;
      } catch (e) {
        console.error('[MindMatch] AI 模块加载失败:', e);
        return false;
      }
    }

    /* ---------- Init ---------- */
    async function init() {
      try {
        console.log('[MindMatch] 开始初始化...');

        await loadCoreModules();

        _profile = _integrate();
        window.__currentProfile = _profile;  // 导出报告用
        console.log('[MindMatch] integrate() 成功, keys=', Object.keys(_profile));
        _translation = _translate(_profile);
        window.__currentTranslation = _translation;  // 导出报告用
        console.log('[MindMatch] translate() 成功');
        const count = _profile.meta.completedCount;
        console.log('[MindMatch] count=', count);

        // 1. 更新完成度徽章
        document.getElementById('completionBadge').textContent =
          count === 4 ? '全部完成' : `已完成 ${count}/4`;

        // 1b. 完成度提示横幅（仅未完成时显示）
        renderConfidenceBanner(count);

        // 2. 渲染维度概览卡片
        _renderOverviewCards('overviewGrid', _profile);
        console.log('[MindMatch] renderOverviewCards() 完成');

        // 3. 渲染图表
        _renderAllCharts(_profile);
        console.log('[MindMatch] renderAllCharts() 完成');

        // 4. 渲染肖像报告
        _renderPortrait('portraitContainer', { translation: _translation, profile: _profile });
        console.log('[MindMatch] renderPortrait() 完成');

        // 5. 加载 AI 模块 + 缓存检查
        if (count === 4) {
          const aiReady = await loadAIModules();
          if (aiReady) {
            // 提取行为叙事
            if (_extractBehaviorNarrative && _formatBehaviorNarrative) {
              const rawData = { game1: load('game1'), game2: load('game2'), game3: load('game3'), game4: load('game4') };
              const bn = _extractBehaviorNarrative(rawData);
              _behaviorNarrativeText = _formatBehaviorNarrative(bn);
              window.__behaviorNarrative = _behaviorNarrativeText;  // 导出报告用
              console.log('[MindMatch] 行为叙事提取完成');
            }
            // 检查是否有缓存的 AI 解读
            if (_hasInsightCache && _hasInsightCache(_profile)) {
              console.log('[MindMatch] 命中 AI 缓存，直接渲染');
              const result = await _generateInsight(_profile, _translation, { behaviorNarrative: _behaviorNarrativeText });
              if (result) {
                window.__insightResult = result;  // 导出报告用
                _renderInsightSuccess('insightCardContainer', result);
                document.getElementById('insightTriggerContainer').style.display = 'none';
              } else {
                _renderInsightTrigger('insightTriggerContainer', handleInsightClick);
              }
            } else {
              _renderInsightTrigger('insightTriggerContainer', handleInsightClick);
            }
          } else {
            const container = document.getElementById('insightTriggerContainer');
            if (container) {
              container.innerHTML = '<div style="padding:20px;text-align:center;color:#6b6b80;font-size:14px;">⚠️ AI 解读模块加载失败，请检查网络或刷新页面重试</div>';
            }
          }
        }

        // 6. 岗位匹配入口
        renderMatchSection(count);
        console.log('[MindMatch] 初始化完成 ✅');
      } catch (err) {
        console.error('[MindMatch] 初始化崩溃:', err);
        const badge = document.getElementById('completionBadge');
        if (badge) { badge.textContent = '初始化失败'; badge.style.color = '#f87171'; }
        const grid = document.getElementById('overviewGrid');
        if (grid) {
          grid.innerHTML = '<div style="grid-column:1/-1;padding:30px;text-align:center;color:#f87171;background:#1a1a2e;border-radius:12px;"><h3>⚠️ 页面初始化失败</h3><p style="margin-top:8px;">' + (err.message || err) + '</p><p style="margin-top:12px;font-size:12px;color:#6b6b80;">请按 Ctrl+F5 强制刷新后重试，如问题持续请截图发给我</p></div>';
        }
      }
    }

    function renderConfidenceBanner(count) {
      const container = document.getElementById('confidenceBanner');
      if (!container || count >= 4 || count === 0) return;

      const messages = {
        1: { emoji: '🌱', text: `仅完成 <strong>${count}/4</strong> 个游戏，画像仅供参考。建议至少完成 3 个游戏以获得更有价值的分析。` },
        2: { emoji: '🌿', text: `已完成 <strong>${count}/4</strong> 个游戏，画像有一定参考价值，但完整度有限。` },
        3: { emoji: '🌳', text: `已完成 <strong>${count}/4</strong> 个游戏，画像具备较高参考价值。完成全部 4 个游戏可获得最完整分析。` },
      };
      const m = messages[count] || messages[1];

      container.innerHTML = `
        <div class="results-confidence-banner">
          <span class="results-confidence-emoji">${m.emoji}</span>
          <p>${m.text}</p>
        </div>
      `;
    }

    function renderMatchSection(count) {
      const matchContainer = document.getElementById('matchContainer');
      if (!matchContainer) return;

      if (count === 4) {
        matchContainer.innerHTML = `
          <div class="match-placeholder match-trigger">
            <div class="match-trigger-icon">🎯</div>
            <h3>职业匹配分析</h3>
            <p>所有游戏已完成！基于你的思维肖像，看看哪些岗位与你最匹配</p>
            <a class="btn-match-trigger" href="match.html?mode=extended">查看职业方向</a>
          </div>
        `;
      } else {
        matchContainer.innerHTML = `
          <div class="match-placeholder">
            <h3>职业匹配即将开放</h3>
            <p>还需完成 <strong>${4 - count}</strong> 个游戏，完成后我们将为你推荐最匹配的岗位方向</p>
          </div>
        `;
      }
    }

    /* ---------- 环境检测 ---------- */
    const _IS_LOCALHOST = location.hostname === 'localhost' || location.hostname === '127.0.0.1';

    /* ---------- API Key 预检 ---------- */
    function checkApiKey() {
      // 云端模式：Key 由云函数环境变量管理，客户端无需检查
      if (!_IS_LOCALHOST) return true;
      // 本地模式：检查 localStorage 中的 Key
      try {
        const raw = localStorage.getItem('mindmatch_api_keys');
        if (!raw) return false;
        const keys = JSON.parse(raw);
        return !!(keys.hunyuanKey || keys.deepseekKey);
      } catch { return false; }
    }

    function showApiKeyMissing() {
      const container = document.getElementById('insightCardContainer');
      if (!container) return;
      // 本地模式：引导配置 Key 或启动 proxy
      const isLocal = _IS_LOCALHOST;
      container.innerHTML = `
        <div class="insight-card" style="border:1px solid rgba(124,58,237,0.3)">
          <div class="insight-loading" style="flex-direction:column;gap:12px;padding:32px 24px">
            <div style="font-size:32px">${isLocal ? '🔑' : '🔧'}</div>
            <p style="font-size:16px;font-weight:600;color:#e0e0f0">${isLocal ? '本地模式：需要配置 API Key' : 'AI 服务暂不可用'}</p>
            <p style="font-size:13px;color:#6b6b80;max-width:400px;text-align:center">${isLocal
              ? '本地开发需要在 localStorage 配置腾讯混元 API Key，并启动本地代理服务器。'
              : '云函数代理暂时无法连接，请稍后重试。如持续不可用，请联系管理员检查云函数状态。'}</p>
            <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center">
              ${isLocal ? `<a href="tools/setup-api.html" target="_blank" class="btn-insight-trigger" style="margin-top:0;text-decoration:none;font-size:13px">前往配置 API Key →</a>` : ''}
              <button onclick="location.reload()" class="btn-insight-trigger" style="margin-top:0;font-size:13px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15)">🔄 刷新页面</button>
            </div>
            <p style="font-size:11px;color:#4a4a60;margin-top:4px" id="insightOriginHint"></p>
          </div>
        </div>
      `;
      const hint = document.getElementById('insightOriginHint');
      if (hint) hint.textContent = `当前站点: ${location.origin}`;
    }

    /* ---------- 跨标签页 Key 同步 ---------- */
    function refreshInsightAfterKeySetup() {
      const trigger = document.getElementById('insightTriggerContainer');
      if (!trigger) return;
      // 清空 insight 容器
      const container = document.getElementById('insightCardContainer');
      if (container) container.innerHTML = '';
      // 如果 AI 模块已加载，用标准触发器；否则用简易按钮
      if (_renderInsightTrigger && _profile && _profile.meta && _profile.meta.completedCount === 4) {
        _renderInsightTrigger('insightTriggerContainer', handleInsightClick);
      } else {
        trigger.innerHTML = `
          <div class="insight-placeholder" style="text-align:center;padding:20px">
            <h3 style="color:#e0e0f0;margin-bottom:8px">API Key 已配置</h3>
            <p style="color:#6b6b80;font-size:13px">数据加载完成后即可使用 AI 解读。若未自动刷新，请手动刷新页面。</p>
            <button onclick="location.reload()" class="insight-trigger-btn" style="margin-top:12px">🔄 刷新页面</button>
          </div>
        `;
      }
      console.log('[MindMatch] 检测到 API Key 变更，UI 已自动刷新');
    }

    (function setupStorageListener() {
      // 云端模式下不需要监听 localStorage 变化（Key 在服务器端）
      if (!_IS_LOCALHOST) return;
      window.addEventListener('storage', (e) => {
        if (e.key === 'mindmatch_api_keys' && e.newValue) {
          try {
            const keys = JSON.parse(e.newValue);
            if (keys.hunyuanKey || keys.deepseekKey) {
              refreshInsightAfterKeySetup();
            }
          } catch {}
        }
      });
      console.log('[MindMatch] storage 监听已就绪, origin=', location.origin);
    })();

    /* ---------- AI 解读点击处理 ---------- */
    async function handleInsightClick(btn) {
      // API Key 预检
      if (!checkApiKey()) {
        showApiKeyMissing();
        btn.disabled = false;
        btn.innerHTML = '<span class="insight-trigger-icon">🔑</span><span>配置 API Key 后重试</span>';
        return;
      }

      btn.disabled = true;
      btn.innerHTML = '<span class="insight-trigger-icon">⏳</span><span>AI 正在分析你的思维特质...</span>';
      _renderInsightLoading('insightCardContainer');

      let lastError = '';

      try {
        console.log('[MindMatch] 调用 _generateInsight...');
        const result = await _generateInsight(_profile, _translation, { skipCache: false, behaviorNarrative: _behaviorNarrativeText });

        if (result) {
          console.log('[MindMatch] AI 解读生成成功');
          window.__insightResult = result;  // 导出报告用
          _renderInsightSuccess('insightCardContainer', result);
          document.getElementById('insightTriggerContainer').style.display = 'none';
          return;
        }
        lastError = 'API 返回空 — 可能超时或额度不足';
      } catch (e) {
        lastError = e.message || String(e);
        console.error('[MindMatch] AI 解读异常:', e);
      }

      _renderInsightError('insightCardContainer', () => handleInsightClick(btn), lastError);
      btn.disabled = false;
      btn.innerHTML = '<span class="insight-trigger-icon">🧠</span><span>重试生成 AI 深度解读</span>';
    }

    document.getElementById('btnRestart').addEventListener('click', () => {
      if (confirm('确定要清空所有数据并重新开始吗？此操作不可撤销。')) {
        clear();
        window.location.href = 'index.html';
      }
    });

    /* ---------- 导出报告 ---------- */
    function packExportData() {
      const exportData = {
        profile: window.__currentProfile || null,
        translation: window.__currentTranslation || null,
        behaviorNarrative: window.__behaviorNarrative || null,
        matchReport: window.__matchReport || null,
        insight: window.__insightResult || null,
        experiment: window.__experimentResult || null,
        generatedAt: new Date().toISOString(),
      };
      localStorage.setItem('mindmatch_export_data', JSON.stringify(exportData));
      window.open('export-report.html', '_blank');
    }

    // 导出按钮事件绑定
    const btnExport = document.getElementById('btnExportReport');
    if (btnExport) {
      btnExport.addEventListener('click', packExportData);
    }

    init();
  </script>

</body>
</html>
