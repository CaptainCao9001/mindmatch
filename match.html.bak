<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MindMatch — 职业方向匹配</title>
  <meta name="description" content="基于你的思维肖像，探索最适合你的六大职业方向，并获取 AI 生成的方向探索计划。">
  <script>window.__MM_VER__ = '20260610b';</script>
  <link rel="stylesheet" href="css/base.css?v=20260610b">
  <link rel="stylesheet" href="css/components.css?v=20260610b">
  <link rel="stylesheet" href="css/match.css?v=20260610b">
</head>
<body class="page-match">

  <!-- ========== Hero ========== -->
  <section class="match-hero">
    <h1>职业方向匹配</h1>
    <p class="match-subtitle">基于你的思维肖像，探索最适合你的六大职业方向</p>
  </section>

  <!-- ========== Mode Tabs ========== -->
  <div class="match-mode-tabs" id="modeTabs">
    <button class="match-mode-tab active" data-mode="experiment" id="tabExperiment">
      🔬 方向探索
    </button>
    <button class="match-mode-tab" data-mode="extended" id="tabExtended">
      🗺️ 职业方向
    </button>
  </div>

  <!-- ========== Content ========== -->
  <div class="match-container" id="matchContainer">

    <!-- Panel 1: Direction Experiments (方向探索) -->
    <div class="match-panel" id="experimentPanel">
      <div class="match-panel-header">
        <h2>方向探索</h2>
        <p class="match-panel-desc">AI 根据你的思维特质，为每个职业方向生成可执行的探索实验。</p>
      </div>
      <div id="experimentContent">
        <div class="match-loading">
          <div class="spinner"></div>
          <p>正在加载方向数据...</p>
        </div>
      </div>
    </div>

    <!-- Panel 2: Extended Direction Match (职业方向) -->
    <div class="match-panel match-panel--hidden" id="directionPanel">
      <div class="match-panel-header">
        <h2>职业方向</h2>
        <p class="match-panel-desc">六大职业方向与你的匹配度排名，点击方向查看具体职业推荐。</p>
      </div>
      <div id="directionContent">
        <div class="match-loading">
          <div class="spinner"></div>
          <p>正在计算匹配度...</p>
        </div>
      </div>
    </div>

  </div>

  <!-- ========== Career Guide CTA ========== -->
  <div class="match-career-guide-cta">
    <a href="career-guide.html?from=match" class="match-career-guide-btn">
      🧭 探索你的职业方向
      <svg viewBox="0 0 24 24" width="18" height="18"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
    </a>
    <p>基于你的测评画像，AI 带你一步步理清职业方向</p>
  </div>

  <!-- ========== Bottom Bar ========== -->
  <div class="match-bottom">
    <a href="results.html" class="btn-secondary">← 返回肖像</a>
    <button id="btnExportFromMatch" class="btn-export">📄 导出报告</button>
    <a href="index.html" class="btn-secondary">返回首页</a>
  </div>

  <!-- ========== App Script ========== -->
  <script type="module">
    import { integrate } from './js/layers/integrator.js?v=20260610b';
    import { matchExtended } from './js/layers/matcher.js?v=20260610b';
    import { renderDirectionResults, renderDirectionCard } from './js/ui/match-ui-extended.js?v=20260610b';
    import { load } from './js/core/store.js?v=20260610b';
    import { extractBehaviorNarrative, formatBehaviorNarrative } from './js/layers/behavior-narrative.js?v=20260610b';
    import { translate } from './js/layers/translator.js?v=20260610b';
    import { generateExperiments, hasExperimentCache } from './js/layers/experiment.js?v=20260610b';
    import { renderExperimentButton, renderExperimentLoading, renderExperimentResult, renderExperimentError } from './js/ui/experiment-card.js?v=20260610b';

    let state = {
      profile: null,
      directionRanking: [],
      behaviorText: '',
      translationText: '',
      generatedExperiments: {},
    };

    // ---- Mode Tab Switching ----
    function switchMode(mode) {
      const expPanel = document.getElementById('experimentPanel');
      const dirPanel = document.getElementById('directionPanel');
      const tabExp = document.getElementById('tabExperiment');
      const tabDir = document.getElementById('tabExtended');

      if (mode === 'experiment') {
        expPanel.classList.remove('match-panel--hidden');
        dirPanel.classList.add('match-panel--hidden');
        tabExp.classList.add('active');
        tabDir.classList.remove('active');
      } else {
        expPanel.classList.add('match-panel--hidden');
        dirPanel.classList.remove('match-panel--hidden');
        tabExp.classList.remove('active');
        tabDir.classList.add('active');
      }
    }

    // ---- Generate experiments for all directions ----
    async function generateAllExperiments() {
      const content = document.getElementById('experimentContent');
      renderExperimentLoading('experimentContent');

      try {
        const result = await generateExperiments(
          state.profile,
          state.directionRanking,
          state.translationText,
          state.behaviorText
        );
        if (result) {
          state.generatedExperiments = result;
          renderExperimentResult('experimentContent', result);
        } else {
          renderExperimentError('experimentContent', 'AI 调用失败，请稍后重试', () => {
            generateAllExperiments();
          });
        }
      } catch (err) {
        renderExperimentError('experimentContent', err.message, () => {
          generateAllExperiments();
        });
      }
    }

    // ---- Init ----
    async function init() {
      try {
        const profile = integrate();
        state.profile = profile;
        const count = profile.meta?.completedCount || 0;

        if (count < 4) {
          document.getElementById('experimentContent').innerHTML = `
            <div class="match-empty">
              <div class="match-empty-icon">🔒</div>
              <h3>还没准备好</h3>
              <p>需要完成全部 4 个思维游戏才能进行方向匹配。<br>当前已完成 <strong>${count}/4</strong>，请先完成剩余游戏。</p>
            </div>
          `;
          document.getElementById('directionContent').innerHTML = `
            <div class="match-empty">
              <div class="match-empty-icon">🔒</div>
              <h3>还没准备好</h3>
              <p>需要完成全部 4 个思维游戏才能进行方向匹配。</p>
            </div>
          `;
          return;
        }

        // Load direction data
        const resp = await fetch('./mock/ideal-profiles.json?v=20260610b');
        if (!resp.ok) throw new Error(`加载数据失败 (HTTP ${resp.status})`);
        const data = await resp.json();

        if (!data.directions || Object.keys(data.directions).length === 0) {
          throw new Error('缺少方向数据');
        }

        // Compute direction ranking
        const matchResult = matchExtended(profile, data);
        const directionRanking = matchResult && matchResult.directionRanking ? matchResult.directionRanking : [];
        state.directionRanking = directionRanking;

        // 存储数据供导出报告使用
        window.__matchReport = matchResult;
        window.__currentProfile = profile;
        window.__behaviorNarrative = state.behaviorText;

        // Behavior narrative + translation (for AI prompt)
        const rawData = { game1: load('game1'), game2: load('game2'), game3: load('game3'), game4: load('game4') };
        const bn = extractBehaviorNarrative(rawData);
        state.behaviorText = formatBehaviorNarrative(bn);
        const translation = translate(profile);
        state.translationText = translation && translation.sections
          ? translation.sections.map(s => `【${s.gameName || s.gameId}】${s.summary || ''}`).join('\n')
          : '';

        // Render direction panel
        renderDirectionResults('directionContent', matchResult);

        // Render experiment panel — show generate button
        renderExperimentButton('experimentContent', () => generateAllExperiments());

      } catch (err) {
        console.error('[MindMatch] 匹配失败:', err);
        document.getElementById('experimentContent').innerHTML = `
          <div class="match-empty">
            <div class="match-empty-icon">⚠️</div>
            <h3>匹配引擎加载失败</h3>
            <p>${err.message || '请返回结果页刷新后重试'}</p>
          </div>
        `;
      }
    }

    // ---- Tab click handlers ----
    document.getElementById('tabExperiment').addEventListener('click', () => switchMode('experiment'));
    document.getElementById('tabExtended').addEventListener('click', () => switchMode('extended'));

    /* ---------- 导出报告 ---------- */
    function packExportData() {
      const exportData = {
        profile: window.__currentProfile || null,
        translation: window.__currentTranslation || null,
        behaviorNarrative: window.__behaviorNarrative || null,
        matchReport: window.__matchReport || null,
        insight: window.__insightResult || null,
        experiment: window.__experimentResult || null,
        generatedAt: new Date().toISOString(),
      };
      localStorage.setItem('mindmatch_export_data', JSON.stringify(exportData));
      window.open('export-report.html', '_blank');
    }

    // 导出按钮事件绑定
    const btnExportMatch = document.getElementById('btnExportFromMatch');
    if (btnExportMatch) {
      btnExportMatch.addEventListener('click', packExportData);
    }

    init();
  </script>

</body>
</html>
